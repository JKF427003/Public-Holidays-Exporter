@model PublicHolidaysExporter.Models.HolidaySearchViewModel
@{
    ViewData["Title"] = "Public Holidays Exporter";
}

<div class="container mt-4">
    <div class="page-header">
        <h1>Public Holidays Exporter</h1>
        <p>Search public holidays by country, year, language, or custom date range</p>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success">@ViewBag.Message</div>   
    }

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="app-panel">
        <form asp-action="Index" method="post" class="row g-3">
            <div class="col-md-4">
                <label asp-for="CountryCode" class="form-label">Country</label>
                <select asp-for="CountryCode" class="form-select">
                    <option value="">Select a country</option>

                    @foreach (var country in Model.Countries)
                    {
                        <option value="@country.IsoCode.Trim().ToUpperInvariant()">
                            @country.Name (@country.IsoCode.Trim().ToUpperInvariant())
                        </option>
                    }
                </select>
                <span asp-validation-for="CountryCode" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Year" class="form-label">Year</label>
                <select asp-for="Year" class="form-select">
                    @foreach (var year in Model.AvailableYears)
                    {
                        <option value="@year">@year</option>
                    }
                </select>
                <input type="hidden" id="YearHidden" name="Year" value="@Model.Year" disabled />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Language" class="form-label">Language</label>
                <select asp-for="Language" class="form-select">
                    <option value="EN">English</option>
                    <option value="MT">Maltese</option>
                    <option value="IT">Italian</option>
                    <option value="DE">German</option>
                </select>
                <span asp-validation-for="Language" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <div class="form-check mt-4">
                    <input asp-for="UseDateRange" class="form-check-input" />
                    <label asp-for="UseDateRange" class="form-check-label">
                        Use custom date range
                    </label>
                </div>
            </div>

            <div class="col-md-4">
                <label asp-for="StartDate" class="form-label">Start Date</label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>

            <div class="col-md-4">
                <label asp-for="EndDate" class="form-label">End Date</label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">
                    Search Holidays
                </button>
            </div>
        </form>
    </div>

    @if (Model.Holidays.Any())
    {
        <div class="app-panel results-section">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
                <h2 class="h4 mb-0">Results</h2>

                <form asp-action="DownloadCsv" method="post" class="mb-0">
                    <input type="hidden" asp-for="CountryCode" />
                    <input type="hidden" asp-for="Year" />
                    <input type="hidden" asp-for="Language" />
                    <input type="hidden" asp-for="UseDateRange" />
                    <input type="hidden" asp-for="StartDate" />
                    <input type="hidden" asp-for="EndDate" />

                    <button type="submit" class="btn btn-success">
                        Download CSV
                    </button>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Holiday Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var holiday in Model.Holidays)
                        {
                            <tr>
                                <td>@holiday.Date.ToString("yyyy-MM-dd")</td>
                                <td>@holiday.Name</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const useDateRangeCheckbox = document.getElementById("UseDateRange");
        const yearSelect = document.getElementById("Year");
        const yearHidden = document.getElementById("YearHidden");
        const startDateInput = document.getElementById("StartDate");
        const endDateInput = document.getElementById("EndDate");

        function updateDateRangeFields() {
            const useDateRange = useDateRangeCheckbox.checked;

            startDateInput.disabled = !useDateRange;
            endDateInput.disabled = !useDateRange;

            yearSelect.disabled = useDateRange;
            yearHidden.disabled = !useDateRange;
            yearHidden.value = yearSelect.value;
        }

        useDateRangeCheckbox.addEventListener("change", updateDateRangeFields);

        yearSelect.addEventListener("change", function () {
            yearHidden.value = yearSelect.value;
        });

        updateDateRangeFields();
    </script>
}