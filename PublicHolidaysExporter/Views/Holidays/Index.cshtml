@{
    ViewData["Title"] = "Public Holidays Exporter";
}

<div class="container mt-4">
    <h1 class="mb-3">Public Holidays Exporter</h1>

    <form method="post" class="row g-3">
        <div class="col-md-4">
            <label for="countryCode" class="form-label">Country Code</label>
            <input type="text" id="countryCode" name="countryCode" class="form-control" placeholder="MT" maxlength="2"/>
        </div>

        <div class="col-md-4">
            <label for="year" class="form-label">Year</label>
            <input type="number" id="year" name="year" class="form-control" placeholder="2026"/>
        </div>

        <div class="col-md-4">
            <label for="language" class="form-label">Language</label>
            <select id="language" name="language" class="form-select">
                <option value="EN" selected>English</option>
                <option value="MT">Maltese</option>
                <option value="IT">Italian</option>
                <option value="DE">German</option>
            </select>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Search Holidays</button>
        </div>
    </form>
</div>