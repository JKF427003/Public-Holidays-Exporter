@model PublicHolidaysExporter.Models.HolidaySearchViewModel
@{
    ViewData["Title"] = "Public Holidays Exporter";
}

<div class="container mt-4">
    <h1 class="mb-3">Public Holidays Exporter</h1>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success">@ViewBag.Message</div>   
    }

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <form asp-action="Index" method="post" class="row g-3">
        <div class="col-md-4">
            <label asp-for="CountryCode" class="form-label">Country Code</label>
            <input asp-for="CountryCode" class="form-control" placeholder="MT" />
            <span asp-validation-for="CountryCode" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Year" class="form-label">Year</label>
            <input asp-for="Year" class="form-control" />
            <span asp-validation-for="Year" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Language" class="form-label">Language</label>
            <select asp-for="Language" class="form-select">
                <option value="EN">English</option>
                <option value="MT">Maltese</option>
                <option value="IT">Italian</option>
                <option value="DE">German</option>
            </select>
            <span asp-validation-for="Language" class="text-danger"></span>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">
                Search Holidays
            </button>
        </div>
    </form>

    @if (Model.Holidays.Any())
    {
        <hr class="my-4"/>

        <h2 class="h4 mb=3">Results</h2>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Holiday Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var holiday in Model.Holidays)
                {
                    <tr>
                        <td>@holiday.Date.ToString("yyyy-MM-dd")</td>
                        <td>@holiday.Name</td>
                    </tr>   
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}