@model List<PublicHolidaysExporter.Models.RecentHolidaySearch>

@{
    ViewData["Title"] = "Recent Searches";
}

<div class="container mt-4">
    <div class="page-header">
        <h1>Recent Searches</h1>
        <p>Review previous searches from this session and download their CSV files.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No recent searches yet.
        </div>
    }
    else
    {
        @foreach (var search in Model)
        {
            <div class="recent-search-card mb-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
                    <div>
                        <h2 class="h5 mb-2">@search.CountryCode - @search.Language</h2>

                        <p class="mb-1">
                            <strong>Date range:</strong>
                            @search.ValidFrom.ToString("yyyy-MM-dd") to @search.ValidTo.ToString("yyyy-MM-dd")
                        </p>

                        <p class="mb-1">
                            <strong>Searched at:</strong>
                            @search.SearchedAt.ToString("yyyy-MM-dd HH:mm")
                        </p>

                        <p class="mb-0">
                            <strong>Results:</strong> @search.Holidays.Count holiday(s)
                        </p>
                    </div>

                    <form asp-action="DownloadRecentCsv" method="post">
                        <input type="hidden" name="id" value="@search.Id" />
                        <button type="submit" class="btn btn-success btn-sm w-100 w-md-auto">
                            Download CSV
                        </button>
                    </form>
                </div>

                @if (search.Holidays.Any())
                {
                    <table class="table table-sm table-striped table-bordered mt-3">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Holiday Name</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var holiday in search.Holidays)
                            {
                                <tr>
                                    <td>@holiday.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@holiday.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
    }
</div>